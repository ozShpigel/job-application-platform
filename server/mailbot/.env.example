# Mailbot environment (copy to .env and fill in). Local convenience only — in
# production Render injects these as real env vars. Keys use __ (mapped to ':').
# The mailbot reads Gmail and applies updates via the Tracker API; it does NOT
# need an Anthropic key (email parsing happens in the API).

# Tracker API to update. Point at your PRIVATE instance (DemoMode off, real DB) —
# a demo-mode API will 403 all writes.
Tracker__BaseUrl=http://localhost:5002

# Gmail OAuth client secrets (Desktop app JSON). Absolute path, or relative to
# the content root. First run opens a browser to authorize; the token is cached.
# If unset and no credentials file is found, the mailbot skips email sync cleanly.
Gmail__CredentialsPath=C:\GitHub\job-application-platform\server\mailbot\credentials.json

# Optional: Gmail search query (default shown).
# Gmail__Query=label:JobApplications newer_than:1d

# --- Per-application re-sync (full history, not just last 24h) ---
# Easiest: pass on the CLI instead — `dotnet run --project server/mailbot -- resync --company "Acme"`.
# Or toggle here (remember to set back to false afterwards):
# Mailbot__Resync=true
# Mailbot__ResyncCompany=Acme
# Mailbot__ResyncTitle=Backend Engineer
