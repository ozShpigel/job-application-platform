{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Gmail": {
    "CredentialsPath": "/etc/secrets/credentials.json",
    "Query": "label:JobApplications newer_than:1d",
    "Label": "JobApplications",
    "ManageFilters": true
  },
  "Tracker": {
    "BaseUrl": "http://localhost:5002"
  }
}
