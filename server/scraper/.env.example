# Scraper environment (copy to .env and fill in).
# Minimum to run: MONGODB_CONNECTION_STRING.

# Required
MONGODB_CONNECTION_STRING=<your-mongodb-connection-string>

# Public read-only demo instance (omit / false on your private instance)
DEMO_MODE=false

# Optional (defaults shown)
# MONGODB_DATABASE_NAME=job-tracker
# API_BASE_URL=http://localhost:5002
# CRON_SECRET=
# CORS_ORIGINS=*
