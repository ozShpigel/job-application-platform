# API environment (copy to .env and fill in). ASP.NET maps __ to config ':'.
# Minimum to run: MongoDB__ConnectionString + Anthropic__ApiKey.

# Required
MongoDB__ConnectionString=<your-mongodb-connection-string>
Anthropic__ApiKey=<your-anthropic-api-key>

# Optional (defaults shown)
# MongoDB__DatabaseName=job-tracker      # tracker DB (applications, interviews)
# MongoDB__ProfileDatabase=jobmatch      # profile / scoring DB
# CorsOrigins=*

# Hosting a public read-only demo? See docs/hosting-a-public-demo.md.
# (Private/local use needs nothing here — DemoMode is off by default.)
