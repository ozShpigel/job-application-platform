# API environment (copy to .env and fill in). ASP.NET maps __ to config ':'.
# Minimum to run: MongoDB__ConnectionString + Anthropic__ApiKey.

# Required
MongoDB__ConnectionString=<your-mongodb-connection-string>
Anthropic__ApiKey=<your-anthropic-api-key>

# Public read-only demo instance (omit / false on your private instance)
DemoMode=false

# Optional (defaults shown)
# MongoDB__DatabaseName=job-tracker
# MongoDB__Database=jobmatch
# CorsOrigins=*
